# ============================================================
# Docker 环境变量模板
# 使用方法：复制此文件为 .env 并修改密码等敏感配置
# cp .env.example .env
# ============================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=123456

# ---- Redis ----
REDIS_PASSWORD=123456

# ---- RabbitMQ ----
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ---- Nacos ----
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
