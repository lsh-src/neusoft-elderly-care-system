# ============================================================
# 生产环境配置 — 复制为 .env 后修改
# cp .env.prod.example .env && vim .env
# ============================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=ChangeMe!Strong@2026

# ---- Redis ----
REDIS_PASSWORD=ChangeMe!Strong@2026

# ---- RabbitMQ ----
RABBITMQ_DEFAULT_USER=elderlycare
RABBITMQ_DEFAULT_PASS=ChangeMe!Strong@2026

# ---- Nacos ----
NACOS_USERNAME=nacos
NACOS_PASSWORD=ChangeMe!Strong@2026
NACOS_AUTH_TOKEN=ChangeMeTo64CharsLongSecretKey012345678901234567890123456789
NACOS_IDENTITY_VALUE=ChangeMeIdentity

# ---- JWT ----
JWT_SECRET=ChangeMe!ToAtLeast32CharsLongSecretKey2026
JWT_EXPIRATION=720

# ---- Aliyun OSS (文件上传) ----
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_BUCKET_NAME=your-bucket-name
ALIYUN_OSS_DOMAIN=https://your-bucket.oss-cn-hangzhou.aliyuncs.com

# ---- AI 模型 (可选) ----
AI_API_KEY=your-mimo-api-key
AI_BASE_URL=https://api.mimo.ai/v1
